<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="120">
    <Properties>
        <Property name="appName">relay-controller</Property>
        <Property name="logPath">${env:LOG_PATH:-/opt/cloud/HDInfraService/logs}</Property>
        <Property name="maxFileSize">${env:LOG_SIZE_POLICY:-20MB}</Property>
        <Property name="maxFiles">${env:LOG_MAX_FILE_COUNT:-30}</Property>
        <Property name="retention">${env:LOG_DELETE_POLICY:-P7D}</Property>
        <Property name="runningPattern">%d{yyyy/MM/dd HH:mm:ss SSS}|%-5p|%c{2}.%M:%L|[%t]|%X{traceId}|%X{parentSpanId}|%X{spanId}|%enc{%.-512msg}{JSON}%ex{20}%n</Property>
        <Property name="accessPattern">V1.0|%d{yyyy/MM/dd HH:mm:ss SSS}|%-5p|%X{traceId}|%X{parentSpanId}|%enc{%msg}{JSON}%n</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${runningPattern}"/>
        </Console>

        <RollingFile name="RunningFile"
                     fileName="${logPath}/running/${appName}.log"
                     filePattern="${logPath}/running/archive/${appName}-%d{yyyy-MM-dd}-%i.log.gz"
                     createOnDemand="true">
            <PatternLayout pattern="${runningPattern}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="${maxFileSize}"/>
            </Policies>
            <DefaultRolloverStrategy max="${maxFiles}">
                <Delete basePath="${logPath}/running/archive" maxDepth="1">
                    <IfFileName glob="*.log.gz">
                        <IfAny>
                            <IfLastModified age="${retention}"/>
                            <IfAccumulatedFileCount exceeds="${maxFiles}"/>
                        </IfAny>
                    </IfFileName>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <RollingFile name="AccessFile"
                     fileName="${logPath}/access/${appName}-access.log"
                     filePattern="${logPath}/access/archive/${appName}-access-%d{yyyy-MM-dd}-%i.log.gz"
                     createOnDemand="true">
            <PatternLayout pattern="${accessPattern}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="${maxFileSize}"/>
            </Policies>
            <DefaultRolloverStrategy max="${maxFiles}">
                <Delete basePath="${logPath}/access/archive" maxDepth="1">
                    <IfFileName glob="*.log.gz">
                        <IfAny>
                            <IfLastModified age="${retention}"/>
                            <IfAccumulatedFileCount exceeds="${maxFiles}"/>
                        </IfAny>
                    </IfFileName>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Logger name="com.baomidou.mybatisplus.core.toolkit.Sequence" level="OFF"/>
        <Logger name="com.huawei.clouds.wushan.pkitoken.iam" level="OFF" additivity="false"/>
        <Logger name="org.flywaydb.core.internal.database.base.Database" level="ERROR"/>
        <Logger name="com.huawei.devbridge.relaycontroller" level="INFO"/>

        <Logger name="accessLogger" level="INFO" additivity="false">
            <AppenderRef ref="AccessFile"/>
        </Logger>
        <Logger name="interfaceLog" level="INFO" additivity="false">
            <AppenderRef ref="AccessFile"/>
        </Logger>

        <Root level="WARN">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RunningFile"/>
        </Root>
    </Loggers>
</Configuration>
