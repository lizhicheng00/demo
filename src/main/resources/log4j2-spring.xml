<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="120" strict="true" name="log4j-relay-controller">
    <Properties>
        <Property name="appName">relay-controller</Property>
        <Property name="delete_policy">${env:LOG_DELETE_POLICY:-P7D}</Property>
        <Property name="size_policy">${env:LOG_SIZE_POLICY:-20MB}</Property>
        <Property name="max_file_count">${env:LOG_MAX_FILE_COUNT:-30}</Property>
        <Property name="log_path">${env:LOG_PATH:-logs}</Property>
        <Property name="running_file_path">${log_path}/running/${appName}.log</Property>
        <Property name="running_file_path_archive">${log_path}/running/archive/${appName}-%d{yyyy-MM-dd}-%i.log.gz</Property>
        <Property name="running_pattern">%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] %logger{36} - %message%n%throwable</Property>
        <Property name="access_file_path">${log_path}/access/${appName}-access.log</Property>
        <Property name="access_file_path_archive">${log_path}/access/archive/${appName}-access-%d{yyyy-MM-dd}-%i.log.gz</Property>
        <Property name="access_pattern">%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %message%n%throwable</Property>
    </Properties>

    <Appenders>
        <Appender type="Console" name="Console" target="SYSTEM_OUT">
            <Layout type="UsPatternLayout" pattern="${running_pattern}"/>
            <Filter type="DynamicThresholdFilter" key="logLevel" defaultThreshold="INFO"
                    onMatch="ACCEPT" onMismatch="DENY"/>
        </Appender>

        <Appender type="RollingFile" name="RunningRollingFile"
                  fileName="${running_file_path}" filePattern="${running_file_path_archive}"
                  filePermissions="rw-r-----">
            <Layout type="UsPatternLayout" pattern="${running_pattern}"/>
            <Filter type="DynamicThresholdFilter" key="logLevel" defaultThreshold="INFO"
                    onMatch="ACCEPT" onMismatch="DENY"/>
            <Policies>
                <Policy type="OnStartupTriggeringPolicy"/>
                <Policy type="TimeBasedTriggeringPolicy" interval="1" modulate="true"/>
                <Policy type="SizeBasedTriggeringPolicy" size="${size_policy}"/>
            </Policies>
            <RolloverStrategy type="DefaultRolloverStrategy" max="${max_file_count}">
                <Action type="PosixViewAttribute" basePath="${log_path}" maxDepth="3"
                        filePermissions="rw-r-----">
                    <PathCondition type="IfFileName" glob="running/archive/*.log.gz"/>
                </Action>
                <Action type="Delete" basePath="${log_path}" maxDepth="3">
                    <PathCondition type="IfFileName" glob="running/archive/*.log.gz">
                        <PathCondition type="IfAny">
                            <PathCondition type="IfLastModified" age="${delete_policy}"/>
                            <PathCondition type="IfAccumulatedFileCount" exceeds="${max_file_count}"/>
                        </PathCondition>
                    </PathCondition>
                </Action>
            </RolloverStrategy>
        </Appender>

        <Appender type="RollingFile" name="AccessRollingFile"
                  fileName="${access_file_path}" filePattern="${access_file_path_archive}"
                  filePermissions="rw-r-----">
            <Layout type="UsPatternLayout" pattern="${access_pattern}"/>
            <Filter type="DynamicThresholdFilter" key="logLevel" defaultThreshold="INFO"
                    onMatch="ACCEPT" onMismatch="DENY"/>
            <Policies>
                <Policy type="OnStartupTriggeringPolicy"/>
                <Policy type="TimeBasedTriggeringPolicy" interval="1" modulate="true"/>
                <Policy type="SizeBasedTriggeringPolicy" size="${size_policy}"/>
            </Policies>
            <RolloverStrategy type="DefaultRolloverStrategy" max="${max_file_count}">
                <Action type="PosixViewAttribute" basePath="${log_path}" maxDepth="3"
                        filePermissions="rw-r-----">
                    <PathCondition type="IfFileName" glob="access/archive/*.log.gz"/>
                </Action>
                <Action type="Delete" basePath="${log_path}" maxDepth="3">
                    <PathCondition type="IfFileName" glob="access/archive/*.log.gz">
                        <PathCondition type="IfAny">
                            <PathCondition type="IfLastModified" age="${delete_policy}"/>
                            <PathCondition type="IfAccumulatedFileCount" exceeds="${max_file_count}"/>
                        </PathCondition>
                    </PathCondition>
                </Action>
            </RolloverStrategy>
        </Appender>

        <Appender type="Async" name="AsyncRunning">
            <AppenderRef ref="RunningRollingFile"/>
        </Appender>
        <Appender type="Async" name="AsyncAccess">
            <AppenderRef ref="AccessRollingFile"/>
        </Appender>
    </Appenders>

    <Loggers>
        <Logger name="com.baomidou.mybatisplus.core.toolkit.Sequence" level="OFF"/>
        <Logger name="org.flywaydb.core.internal.database.base.Database" level="ERROR"/>
        <Logger name="com.huawei.devbridge.relaycontroller.RelayControllerApplication" level="INFO"/>
        <Logger name="com.huawei.devbridge.relaycontroller.application.service" level="INFO"/>

        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncRunning"/>
        </Root>
        <Logger name="accessLogger" level="INFO" additivity="false">
            <AppenderRef ref="AsyncAccess"/>
        </Logger>
        <Logger name="interfaceLog" level="INFO" additivity="false">
            <AppenderRef ref="AsyncAccess"/>
        </Logger>
    </Loggers>
</Configuration>
